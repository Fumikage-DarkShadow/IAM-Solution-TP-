{
  "name": "Keycloak SSO + JWT Decoder",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "version": "latest"
    }
  },
  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": {
      "label": "React SPA",
      "onAutoForward": "openPreview",
      "visibility": "public"
    },
    "8080": {
      "label": "Keycloak",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "postCreateCommand": "npm install --no-audit --no-fund",
  "postStartCommand": "docker compose up -d",
  "postAttachCommand": {
    "vite": "echo '' && echo '🚀 Keycloak boots in ~45s — wait until http://localhost:8080/realms/efrei-iam/.well-known/openid-configuration returns 200, then run:  npm run dev'"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "remoteUser": "node"
}
